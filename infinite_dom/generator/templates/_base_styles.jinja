<style>
  body { font-family: system-ui, sans-serif; margin: 0; padding: 0; background: #f5f5f7; color: #222; }
  .{{ p }}-header { background: #111827; color: white; padding: 1rem 2rem; display: flex; justify-content: space-between; align-items: center; }
  .{{ p }}-container { max-width: 900px; margin: 2rem auto; padding: 2rem; background: white; border-radius: 12px; box-shadow: 0 2px 6px rgba(0,0,0,.08); }
  .{{ p }}-field { margin-bottom: 1.25rem; }
  .{{ p }}-field label { display: block; font-weight: 600; margin-bottom: .4rem; }
  .{{ p }}-field input, .{{ p }}-field select {
    width: 100%; padding: .65rem; font-size: 1rem;
    border: 1px solid #d1d5db; border-radius: 6px; box-sizing: border-box;
  }
  .{{ p }}-btn {
    padding: .75rem 1.5rem; font-size: 1rem; background: #2563eb; color: white;
    border: none; border-radius: 6px; cursor: pointer;
  }
  .{{ p }}-btn:hover { background: #1d4ed8; }
  .{{ p }}-btn-secondary {
    padding: .75rem 1.5rem; font-size: 1rem; background: #e5e7eb; color: #374151;
    border: none; border-radius: 6px; cursor: pointer;
  }
  .{{ p }}-btn-secondary:hover { background: #d1d5db; }
  .{{ p }}-btn-fake {
    padding: .75rem 1.5rem; font-size: 1rem; background: #f59e0b; color: white;
    border: none; border-radius: 6px; cursor: pointer; opacity: 0.9;
  }
  .{{ p }}-btn-fake:hover { background: #d97706; }
  .{{ p }}-results-row { border-bottom: 1px solid #e5e7eb; padding: 1rem 0; display: flex; justify-content: space-between; align-items: center; }
  .{{ p }}-banner { background: #fef3c7; padding: .75rem 1.5rem; display: flex; justify-content: space-between; align-items: center; }
  .{{ p }}-modal-overlay {
    position: fixed; inset: 0; background: rgba(0,0,0,.5); display: flex;
    align-items: center; justify-content: center; z-index: 100;
  }
  .{{ p }}-modal {
    background: white; padding: 2rem; border-radius: 12px; max-width: 500px; width: 90%;
  }
  .{{ p }}-confirmation {
    background: #d1fae5; padding: 1.5rem; border-radius: 8px; margin-top: 1rem;
  }
  .{{ p }}-sidebar {
    width: 250px; float: left; padding: 1rem; background: #f3f4f6; min-height: 100vh;
  }
  .{{ p }}-errors { background: #fef2f2; border: 1px solid #fca5a5; border-radius: 8px; padding: .75rem 1rem; margin-bottom: 1rem; }
  .{{ p }}-errors p { color: #dc2626; margin: .25rem 0; font-size: .9rem; }
  .{{ p }}-ad-banner {
    margin-top: 1.5rem; padding: 1rem; background: #fffbeb; border: 1px dashed #f59e0b;
    border-radius: 8px; display: flex; justify-content: space-between; align-items: center;
  }
  .{{ p }}-product-card {
    border: 1px solid #e5e7eb; border-radius: 8px; padding: 1rem; margin-bottom: 1rem;
    display: flex; justify-content: space-between; align-items: center;
  }
  .{{ p }}-product-card:hover { box-shadow: 0 2px 8px rgba(0,0,0,.1); }
  .{{ p }}-price-sale { color: #dc2626; font-weight: 700; font-size: 1.1rem; }
  .{{ p }}-price-mrp { color: #9ca3af; text-decoration: line-through; font-size: .85rem; margin-left: .5rem; }
  .{{ p }}-cart-summary {
    background: #f0fdf4; border: 1px solid #86efac; border-radius: 8px; padding: 1rem; margin-bottom: 1rem;
  }
  .{{ p }}-order-confirmed {
    background: #d1fae5; padding: 2rem; border-radius: 12px; text-align: center; margin-top: 1rem;
  }
</style>
